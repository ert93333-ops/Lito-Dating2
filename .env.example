# ============================================================
# LITO API Server — .env.example
# 모든 필수 환경변수 목록. 실제 값은 별도 .env 에 설정.
# ============================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lito

# Redis
REDIS_URL=redis://localhost:6379

# Session / JWT
SESSION_SECRET=change_me_32_chars_min
JWT_REFRESH_SECRET=change_me_jwt_refresh_32_chars_min

# External AI Provider (번역/코칭)
EXTERNAL_AI_API_KEY=

# Apple Sign-In
# NOTE: Apple secure re-enable is pending (see docs/policy/open_questions.md)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email Provider (OTP 인증)
EMAIL_PROVIDER_API_KEY=

# Object Storage
STORAGE_BUCKET=
STORAGE_REGION=

# Billing — Apple IAP
# lito_ai_coach_10 / lito_ai_coach_30 / lito_ai_coach_70
BILLING_APPLE_SHARED_SECRET=

# Billing — Google Play
BILLING_GOOGLE_SERVICE_ACCOUNT_JSON=

# Analytics
ANALYTICS_WRITE_KEY=

# Account Deletion Web Handoff URL
# 사용자가 앱에서 삭제 시작 후 이동하는 웹 URL
WEB_DELETE_BASE_URL=https://litodate.app/delete

# Contact Block Hash Salt
# 연락처를 원문 저장하지 않고 hash로 저장하기 위한 salt
CONTACT_HASH_SALT=change_me_contact_hash_salt

# App Config
NODE_ENV=development
PORT=8080
