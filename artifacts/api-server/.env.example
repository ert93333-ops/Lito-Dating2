# =============================================
# LITO API 서버 환경변수 템플릿
# artifacts/api-server/.env
#
# 이 파일을 .env로 복사한 뒤 값을 채워주세요.
# =============================================

# ── 서버 기본 설정 ────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── JWT 서명 시크릿 (필수) ────────────────────
# openssl rand -hex 32 로 생성
SESSION_SECRET=

# ── PostgreSQL 데이터베이스 (필수) ────────────
DATABASE_URL=postgresql://user:password@host:5432/lito_db

# ── OpenAI API (AI 기능용) ────────────────────
OPENAI_API_KEY=

# ── Google OAuth ──────────────────────────────
# 리디렉션 URI: https://YOUR_DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kakao OAuth ───────────────────────────────
KAKAO_APP_KEY=
KAKAO_CLIENT_SECRET=

# ── LINE OAuth ────────────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ── Object Storage (Google Cloud Storage) ────
# GCS 버킷 이름 (미설정 시 로컬 파일시스템 폴백)
GCS_BUCKET_NAME=
# GCS 서비스 계정 JSON 키 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=

# ── 프로덕션 플래그 ──────────────────────────
# AI 페르소나 유저를 discover에 주입 (프로덕션: false)
ENABLE_AI_PERSONAS=false
# 데모 유저를 discover에 주입 (프로덕션: false)
ENABLE_DEMO_USERS=false

# ── Admin ─────────────────────────────────────
# 관리자 API 토큰 (x-admin-token 헤더)
ADMIN_TOKEN=

# ── API 서버 외부 URL (로컬 업로드 모드에서만 사용) ──
# 프로덕션에서 GCS 사용 시 불필요
# API_BASE_URL=https://api.litodate.app
