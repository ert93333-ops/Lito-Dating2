# =============================================
# LITO Expo 앱 환경변수 템플릿
# artifacts/lito/.env
#
# Expo는 빌드 타임에 EXPO_PUBLIC_ 접두사 변수만 번들에 포함합니다.
# 이 파일을 .env로 복사한 뒤 값을 채워주세요.
# =============================================

# ── API 서버 도메인 (필수) ────────────────────
# 프로덕션: 실제 API 서버 도메인 (프로토콜 제외)
# 로컬 개발: 비워두면 http://localhost:3000 폴백
EXPO_PUBLIC_DOMAIN=api.litodate.app

# ── Feature Flags ─────────────────────────────
# AI 페르소나 대화방 (개발용, 프로덕션에서는 반드시 false)
EXPO_PUBLIC_ENABLE_AI_PERSONAS=false
